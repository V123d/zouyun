# ============================================================
# 走云智能排菜系统 — 环境变量配置模板
#
# 使用方法：
#   1. 复制本文件为 .env      →  cp .env.example .env
#   2. 填入以下配置
# ============================================================

# === [核心能力] 大模型 API 配置 ===
# 百度文心 API 地址
LLM_API_URL=https://aistudio.baidu.com/llm/lmapi/v3

# ⚠️ 必填：在此填入您的百度文心 API Key
# 申请地址：https://aistudio.baidu.com/index/accessor/llm
LLM_API_KEY=your-api-key-here

# 模型名称
LLM_MODEL=ernie-4.5-turbo-128k-preview

# === [安全] 业务与认证配置 ===
# 用于对 JWT Token 进行签名的密钥，生产环境必须使用强随机字符串（如：openssl rand -hex 32）
JWT_SECRET_KEY=your-production-secret-key

# === [基础设施] 数据库连接 ===
# 开发环境已注释（默认使用本地 SQLite），生产环境填入 Postgres 的异步连接串
# 示例：DATABASE_URL=postgresql+asyncpg://user:password@db:5432/zouyun_db
# DATABASE_URL=

# === [部署] 服务端点配置 ===
HOST=0.0.0.0
PORT=8000
DEBUG=False
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8000
