# ============================================================
# 走云智能排菜系统 — 环境变量配置模板
#
# 使用方法：
#   1. 复制本文件为 .env      →  cp .env.example .env
#   2. 填入以下配置
# ============================================================

# === [核心能力] 大模型 API 配置 ===
# 通义千问 API 地址（默认值无需修改，除非使用其他兼容 OpenAI 格式的模型服务）
LLM_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ⚠️ 必填：在此填入您的通义千问 API Key
# 申请地址：https://dashscope.console.aliyun.com/
LLM_API_KEY=sk-your-api-key-here

# 模型名称（推荐 qwen-max，也支持 qwen-plus / qwen-turbo）
LLM_MODEL=qwen-max

# === [安全] 业务与认证配置 ===
# 用于对 JWT Token 进行签名的密钥，生产环境必须使用强随机字符串（如：openssl rand -hex 32）
JWT_SECRET_KEY=your-production-secret-key

# === [基础设施] 数据库连接 ===
# 开发环境可留空（默认使用本地 SQLite），生产环境填入 Postgres 的异步连接串
# 示例：DATABASE_URL=postgresql+asyncpg://user:password@db:5432/zouyun_db
DATABASE_URL=

# === [部署] 服务端点配置 ===
HOST=0.0.0.0
PORT=8000
DEBUG=False
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8000
